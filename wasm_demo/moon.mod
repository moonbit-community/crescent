name = "bobzhang/crescent_wasm_demo"

version = "0.1.0"

import {
  "bobzhang/crescent@0.11.0",
  "moonbitlang/async@0.20.3",
}

readme = "README.mbt.md"

repository = "https://github.com/moonbit-community/crescent"

license = "Apache-2.0"

keywords = [ "http", "server", "wasm", "example", "crescent" ]

preferred_target = "wasm"

description = "A minimal Crescent web server that also builds for the wasm target."
